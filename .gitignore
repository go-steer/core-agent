# Binaries for programs and plugins.
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binaries built with `go test -c`.
*.test

# Coverage profiles + other test artifacts.
*.out
coverage.*
*.coverprofile
profile.cov

# Project-specific binaries (built from ./cmd/... and ./examples/...).
/core-agent
/cmd/core-agent/core-agent
/examples/basic/basic
/examples/with-tools/with-tools

# GoReleaser output (`goreleaser release --snapshot --clean`).
/dist/

# Release notes composed by .github/workflows/release.yml's
# "Compose release notes" step from the matching CHANGELOG.md
# section. Written into the working tree so goreleaser's
# --release-notes flag can read it; must be gitignored so
# goreleaser's dirty-tree check doesn't fail on it. Also
# suppresses spurious "untracked file" noise from local dry-runs
# (`goreleaser release --snapshot --clean`).
/RELEASE_NOTES.md

# Mast-web embed bundle — populated by dev/tools/fetch-mast-web at
# build time, kept out of git so we don't carry a binary copy of
# another repo's release.
/internal/webui/dist/*
!/internal/webui/dist/.gitkeep

# AI assistant working state — never committed to this repo.
.claude/

# Per-user .agents/ state.
/.agents/sessions/
/.agents/logs/

# Local environment overrides.
.env
.env.local

# Editor / IDE noise.
.idea/
.vscode/
.DS_Store
*.swp

# Personal working notes — kept on disk but not in version control.
TODO.md
