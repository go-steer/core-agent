set -euo pipefail

# Latest RELEASE tag. Exclude pre-releases: SemVer says any hyphen
# after the version triple denotes a pre-release (v2.7.0-dev.1,
# v2.7.0-rc.1, ...). Sort by version-aware refname so newest lands
# first regardless of tag creation order.
LATEST_RELEASE=$(git tag --list 'v*.*.*' --sort=-v:refname \
                  | grep -v '-' | head -1 || true)

if [[ -z "$LATEST_RELEASE" ]]; then
    echo "verify-version-fallback: no release tags found" >&2
    echo "  If this is a fresh CI checkout, ensure fetch-tags: true" >&2
    echo "  is set on actions/checkout." >&2
    exit 1
fi

if [[ ! "$LATEST_RELEASE" =~ ^v([0-9]+)\.([0-9]+)\.([0-9]+)$ ]]; then
    echo "verify-version-fallback: latest release tag '${LATEST_RELEASE}'" >&2
    echo "  doesn't parse as vX.Y.Z" >&2
    exit 1
fi
MAJOR="${BASH_REMATCH[1]}"
MINOR="${BASH_REMATCH[2]}"
EXPECTED="v${MAJOR}.$((MINOR + 1)).0-dev"

# Read the current fallback from source. Pin to the first
# `Version = "..."` in the file so a future const near it can't
# accidentally shadow the match.
ACTUAL=$(grep -oE 'Version = "[^"]+"' internal/version/version.go \
         | head -1 | grep -oE '"[^"]+"' | tr -d '"')

if [[ "$ACTUAL" != "$EXPECTED" ]]; then
    cat >&2 <<EOF
verify-version-fallback: internal/version/version.go's Version
fallback is out of sync with the release history.

  Latest release tag: ${LATEST_RELEASE}
  Expected fallback:  ${EXPECTED}
  Actual fallback:    ${ACTUAL}

Bump the constant in internal/version/version.go:
  Version = "${EXPECTED}"

The pattern lives in docs/release-process.md (step 4): after
cutting a release tag, main's fallback should report the next
target version so plain \`go install\` / \`go build\` (no ldflag
injection) reports a sensible --version.
EOF
    exit 1
fi

echo "verify-version-fallback: OK (${ACTUAL} matches next-target after ${LATEST_RELEASE})"
