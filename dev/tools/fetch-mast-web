# fetch-mast-web — downloads the pinned mast-web release tarball and
# extracts it into internal/webui/dist/ so the agent's --ui flag has
# real assets to serve via //go:embed.
#
# Usage:
#   dev/tools/fetch-mast-web              # use version from .mast-web-version
#   dev/tools/fetch-mast-web v0.2.0       # one-off override
#
# Behavior:
#   - Reads the version from the top-level .mast-web-version file
#     (key=value, version=vX.Y.Z) unless an argument is supplied
#   - If no version is pinned (blank file or missing), prints a notice
#     and exits 0 — the build still succeeds; --ui at runtime emits a
#     clear error about the missing assets
#   - Downloads from the GitHub release at
#     https://github.com/go-steer/mast-web/releases/download/<tag>/mast-web-<tag>.tar.gz
#   - Verifies the SHA256 against the .sha256 sidecar published with
#     the release; refuses to extract on mismatch
#   - Extracts to internal/webui/dist/, replacing any previous contents
set -euo pipefail
. "$(dirname "$0")/common.sh"
cd "$(repo_root)"

version="${1:-}"
if [[ -z "$version" ]] && [[ -f .mast-web-version ]]; then
  # Strip comments + blank lines, then extract version= value.
  version=$(grep -E '^version=' .mast-web-version | head -n1 | cut -d= -f2- | tr -d '[:space:]' || true)
fi

if [[ -z "$version" ]]; then
  echo "▸ fetch-mast-web: no version pinned in .mast-web-version (and none passed) — skipping" >&2
  echo "  --ui at runtime will print a clear error explaining the assets aren't populated yet." >&2
  exit 0
fi

dest="internal/webui/dist"
tag="$version"
asset="mast-web-${tag}.tar.gz"
base="https://github.com/go-steer/mast-web/releases/download/${tag}"
tmp="$(mktemp -d)"
trap 'rm -rf "$tmp"' EXIT

echo "▸ fetch-mast-web: downloading ${asset} (pinned via .mast-web-version)"
curl -sSLf -o "${tmp}/${asset}"        "${base}/${asset}"
curl -sSLf -o "${tmp}/${asset}.sha256" "${base}/${asset}.sha256"

echo "▸ fetch-mast-web: verifying sha256"
(cd "$tmp" && sha256sum -c "${asset}.sha256")

echo "▸ fetch-mast-web: extracting into ${dest}/"
# Preserve the .gitkeep so the directory always shows up as tracked.
mkdir -p "$dest"
find "$dest" -mindepth 1 ! -name '.gitkeep' -delete
tar -xzf "${tmp}/${asset}" -C "$dest"

echo "▸ fetch-mast-web: done ($(find "$dest" -type f | wc -l | tr -d ' ') files in ${dest}/)"
