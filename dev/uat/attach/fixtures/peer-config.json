{
  "version": 1,
  "model": {
    "provider": "echo",
    "name": "echo"
  },
  "permissions": {
    "mode": "yolo"
  },
  "attach": {
    "listen":            "0.0.0.0:7780",
    "token_env":         "ATTACH_TOKEN",
    "readonly":          false,
    "peer_hub":          false,

    "register_to":       "http://localhost:7777",
    "register_endpoint": "http://${POD_IP}:7780",
    "register_name":     "monitor-${HOSTNAME_OVERRIDE}"
  }
}
