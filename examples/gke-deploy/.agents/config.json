{
  "version": 1,
  "model": {
    "provider": "vertex",
    "name": "gemini-3.1-pro-preview-customtools",
    "vertex": {
      "project": "${GOOGLE_CLOUD_PROJECT}",
      "location": "${GOOGLE_CLOUD_LOCATION}"
    }
  },
  "permissions": {
    "mode": "ask",
    "allow": [
      "read_file",
      "read_many_files",
      "stat",
      "list_dir",
      "glob",
      "grep",
      "json_query",
      "fetch_url",
      "todo"
    ]
  },
  "agent": {
    "display_name": "core-agent (GKE)"
  }
}
