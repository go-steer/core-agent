# DO NOT commit this file with a real token. Copy to 20-secret.yaml
# locally and run the create command below to populate it, OR skip
# the file and create the Secret imperatively (recommended):
#
#   kubectl create secret generic core-agent \
#     --namespace agent-system \
#     --from-literal=attach-token="$(openssl rand -hex 32)"
#
# The deployment references this secret via env.valueFrom.secretKeyRef
# so the bearer token never appears in pod specs or ConfigMaps.
# Operators retrieve it for `core-agent-tui --attach-token=<value>`
# via:
#
#   kubectl get secret -n agent-system core-agent \
#     -o jsonpath='{.data.attach-token}' | base64 -d
#
# Rotating the token: re-run `kubectl create secret ... --dry-run -o yaml |
# kubectl apply -f -` then restart the deployment (`kubectl rollout
# restart deployment/core-agent -n agent-system`). Active TUI sessions
# break and need to re-attach.
apiVersion: v1
kind: Secret
metadata:
  name: core-agent
  namespace: agent-system
type: Opaque
data:
  # base64-encoded bearer token; populated via the kubectl create
  # command above. Placeholder shown here is the base64 of
  # "REPLACE_ME_WITH_REAL_TOKEN" — must not ship.
  attach-token: UkVQTEFDRV9NRV9XSVRIX1JFQUxfVE9LRU4=
